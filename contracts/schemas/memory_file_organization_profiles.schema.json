{
  "title": "Memory File Organization Profiles",
  "type": "object",
  "required": [
    "version",
    "name",
    "description",
    "profiles"
  ],
  "properties": {
    "version": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "enabled",
          "source_code",
          "incoming_path",
          "managed_root",
          "baseline_profile",
          "physical_move_policy",
          "source_delete_policy",
          "storage_backend",
          "future_backends",
          "proposal_thresholds"
        ],
        "properties": {
          "enabled": { "type": "boolean" },
          "source_code": { "type": "string" },
          "incoming_path": {
            "type": "string",
            "pattern": "^[^/\\\\][^:]*$"
          },
          "managed_root": { "type": "string" },
          "baseline_profile": { "type": "string" },
          "physical_move_policy": {
            "type": "string",
            "enum": ["approval_required", "disabled"]
          },
          "source_delete_policy": {
            "type": "object",
            "required": [
              "mode",
              "retention_days",
              "requires_backup_checkpoint"
            ],
            "properties": {
              "mode": {
                "type": "string",
                "enum": ["quarantine_then_purge", "quarantine_only", "disabled"]
              },
              "retention_days": { "type": "integer", "minimum": 0 },
              "requires_backup_checkpoint": { "type": "boolean" }
            },
            "additionalProperties": false
          },
          "storage_backend": {
            "type": "string",
            "enum": ["managed_fs", "s3_compatible"]
          },
          "future_backends": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["managed_fs", "s3_compatible"]
            },
            "uniqueItems": true
          },
          "proposal_thresholds": {
            "type": "object",
            "required": [
              "min_users",
              "min_events",
              "min_files",
              "min_confidence"
            ],
            "properties": {
              "min_users": { "type": "integer", "minimum": 1 },
              "min_events": { "type": "integer", "minimum": 1 },
              "min_files": { "type": "integer", "minimum": 1 },
              "min_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
