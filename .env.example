DJANGO_ENV=development
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_INTERNAL_ALLOWED_HOSTS=web
LOCAL_BUSINESS_SHARED_NETWORK=local-business-suite_internal
APP_DISPLAY_NAME=Корпоративный портал ВОБ №3
DJANGO_AUTH_MODE=hybrid
AD_LDAP_TRANSPORT=plain
AD_LDAP_ALLOW_INSECURE=true
AD_LDAP_VERIFY_CERT=false
AD_LDAP_HOST=dc01.mscher.local
AD_LDAP_PORT=389
AD_LDAP_DOMAIN=MSCHER
AD_SEARCH_DN=DC=mscher,DC=local
AD_SERVICE_ACCOUNT=MSCHER\svc_local_business
AD_SERVICE_PASSWORD=change-me
AD_LDAP_USER_FILTER=(sAMAccountName={username})
AD_GROUP_ROLE_MAP={"Domain Admins":"manager","IT Support":"technician","Employees":"customer"}
AD_LDAP_CA_FILE=
LOCAL_BUSINESS_AI_GATEWAY_TOKEN=change-me
LOCAL_BUSINESS_AGENT_RUNTIME_URL=http://127.0.0.1:8090
LOCAL_BUSINESS_AGENT_RUNTIME_TIMEOUT=90
GUNICORN_TIMEOUT=600
GUNICORN_GRACEFUL_TIMEOUT=30
LOCAL_BUSINESS_AI_PENDING_ACTION_TTL_SECONDS=900
LOCAL_BUSINESS_AI_REGISTRY_FILE=
LOCAL_BUSINESS_AI_TOOLS_FILE=
LOCAL_BUSINESS_AI_TASK_TYPES_FILE=
LOCAL_BUSINESS_AI_MODELS_FILE=
LOCAL_BUSINESS_ANALYTICS_DATASETS_FILE=
DJANGO_AI_GATEWAY_URL=http://127.0.0.1:8000/ai/gateway
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_AGENT_MODEL=openai:gpt-4.1-mini
AI_AGENT_MODEL_NAME=gpt-4.1-mini
AI_AGENT_SYSTEM_PROMPT_FILE=services/agent_runtime/prompts/hospital_system_prompt.txt
# False values are allowed only for the current HTTP-only trusted LAN/VPN profile.
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
