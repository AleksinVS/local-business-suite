{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Business Notifier",
  "version": "0.1.0",
  "identifier": "ru.vob3.local-business-suite.notifier",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Уведомления портала",
        "width": 520,
        "height": 640,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:* http://localhost:* https://*; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage", "deb"],
    "icon": ["icons/icon.png"]
  }
}
