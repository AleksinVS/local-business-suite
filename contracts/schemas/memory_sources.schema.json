{
  "title": "Memory Sources",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "code",
      "title",
      "description",
      "source_kind",
      "domain",
      "owner",
      "enabled",
      "sync_mode",
      "schedule",
      "source_ref",
      "scope_rule",
      "sensitivity",
      "pii_policy",
      "versioning_mode",
      "retention_policy",
      "extractor_profile",
      "chunking_profile",
      "index_profiles",
      "ignore_patterns"
    ],
    "properties": {
      "code": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "title": { "type": "string" },
      "description": { "type": "string" },
      "source_kind": {
        "type": "string",
        "enum": [
          "django_model",
          "contract_file",
          "documentation",
          "integration_snapshot",
          "external_api_snapshot",
          "local_path",
          "unc_path",
          "synthetic_fixture"
        ]
      },
      "domain": { "type": "string" },
      "owner": { "type": "string" },
      "enabled": { "type": "boolean" },
      "sync_mode": {
        "type": "string",
        "enum": ["manual", "scheduled", "incremental"]
      },
      "schedule": {
        "type": ["string", "null"]
      },
      "source_ref": { "type": "string" },
      "scope_rule": {
        "type": "string",
        "enum": [
          "public_knowledge",
          "authenticated_user",
          "role_scoped",
          "workorder_visibility",
          "inventory_visibility",
          "contract_admin",
          "manual_scope_mapping"
        ]
      },
      "sensitivity": {
        "type": "string",
        "enum": [
          "public",
          "internal",
          "confidential",
          "pii_redacted",
          "pii_original",
          "secret"
        ]
      },
      "pii_policy": {
        "type": "string",
        "enum": [
          "no_pii_expected",
          "reject_pii",
          "deidentify_before_index",
          "allow_redacted_only"
        ]
      },
      "versioning_mode": {
        "type": "string",
        "enum": [
          "snapshot_only",
          "hard_active_soft_raw",
          "append_only"
        ]
      },
      "retention_policy": {
        "type": "string",
        "enum": [
          "default_public",
          "default_internal",
          "short_lived_eval",
          "external_default",
          "short_lived_raw_quarantine"
        ]
      },
      "trust_status": {
        "type": "string",
        "enum": ["trusted", "review_required", "blocked", "candidate_only", "quarantined"]
      },
      "authority_class": {
        "type": "string",
        "enum": [
          "system_of_record",
          "approved_corpus",
          "approved_user_memory",
          "reviewed_org_knowledge",
          "external_observation",
          "candidate_input"
        ]
      },
      "trusted_for_context": {
        "type": "boolean"
      },
      "requires_source_review": {
        "type": "boolean"
      },
      "review_owner": {
        "type": "string"
      },
      "trusted_context_kinds": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "question",
            "retrieved_chunk",
            "citation",
            "metadata",
            "graph_fact",
            "claim",
            "belief"
          ]
        },
        "uniqueItems": true
      },
      "untrusted_handling": {
        "type": "string",
        "enum": ["review_required", "blocked", "candidate_only", "quarantine", "block"]
      },
      "extractor_profile": { "type": "string" },
      "chunking_profile": { "type": "string" },
      "index_profiles": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 1,
        "uniqueItems": true
      },
      "ignore_patterns": {
        "type": "array",
        "items": { "type": "string" }
      },
      "ingestion_profile": {
        "type": "string"
      },
      "external_connector": {
        "type": "object",
        "required": [
          "queue_backend",
          "raw_mode",
          "scope_mapping",
          "retention"
        ],
        "properties": {
          "queue_backend": {
            "type": "string",
            "enum": ["sqlite"]
          },
          "raw_mode": {
            "type": "string",
            "enum": ["metadata_only", "normalized_only", "short_lived_raw_quarantine"]
          },
          "scope_mapping": {
            "type": "string",
            "enum": ["manual"]
          },
          "retention": {
            "type": "object",
            "properties": {
              "raw_quarantine_days": { "type": "integer", "minimum": 1 },
              "normalized_envelope_days": { "type": "integer", "minimum": 1 },
              "manifest_days": { "type": "integer", "minimum": 1 },
              "tombstone_days": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
