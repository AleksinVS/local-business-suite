DJANGO_ENV=development
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,stc-web,web
DJANGO_INTERNAL_ALLOWED_HOSTS=web
LOCAL_BUSINESS_SHARED_NETWORK=local-business-suite_internal
APP_DISPLAY_NAME=Корпоративный портал ВОБ №3
LOCAL_BUSINESS_DB_BACKEND=sqlite
# Production target for the main repository is PostgreSQL.
# For Docker Compose, set LOCAL_BUSINESS_DB_BACKEND=postgresql and use these variables:
POSTGRES_DB=local_business_suite
POSTGRES_USER=local_business_app
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
# DATABASE_URL can be used instead of POSTGRES_*:
# DATABASE_URL=postgresql://local_business_app:change-me@127.0.0.1:5432/local_business_suite
# Emergency-only override for the main repository; prefer the SQLite fork for small installs.
LOCAL_BUSINESS_ALLOW_SQLITE_PRODUCTION=false
# Auxiliary SQLite is allowed only for development or the SQLite fork.
LOCAL_BUSINESS_ALLOW_SQLITE_AUXILIARY_PRODUCTION=false
# For production PostgreSQL profile use:
# LOCAL_BUSINESS_MEMORY_FULLTEXT_BACKEND=postgresql
# LOCAL_BUSINESS_EXTERNAL_CONNECTOR_QUEUE_BACKEND=database
LOCAL_BUSINESS_MEMORY_FULLTEXT_BACKEND=sqlite_fts
LOCAL_BUSINESS_EXTERNAL_CONNECTOR_QUEUE_BACKEND=sqlite
DJANGO_AUTH_MODE=hybrid
AD_LDAP_TRANSPORT=plain
AD_LDAP_ALLOW_INSECURE=true
AD_LDAP_VERIFY_CERT=false
AD_LDAP_HOST=192.168.251.1
AD_LDAP_PORT=389
AD_LDAP_DOMAIN=MSCHER
AD_SEARCH_DN=DC=mscher,DC=local
AD_SERVICE_ACCOUNT=MSCHER\svc_local_business
AD_SERVICE_PASSWORD=change-me
AD_LDAP_USER_FILTER=(sAMAccountName={username})
AD_GROUP_ROLE_MAP={"Domain Admins":"manager","IT Support":"technician","Employees":"customer"}
AD_LDAP_CA_FILE=
LOCAL_BUSINESS_AI_GATEWAY_TOKEN=change-me
LOCAL_BUSINESS_AGENT_RUNTIME_URL=http://127.0.0.1:8090
LOCAL_BUSINESS_AGENT_RUNTIME_TIMEOUT=90
# AI UI driver for the in-portal chat surface: "native" (по умолчанию,
# самописный AG-UI-compatible чат, static/src/ai_ui/native_ai.js) или
# "copilotkit" (требует `npm run build:copilotkit`, собирает
# static/dist/copilotkit/). Драйвер "legacy" выведен из проекта (ADR-0032):
# это значение роняет Django на старте с ImproperlyConfigured.
LOCAL_BUSINESS_AI_UI_DRIVER=native
LOCAL_BUSINESS_AI_UI_PROTOCOL_VERSION=1.0
LOCAL_BUSINESS_AI_UI_AGUI_PROFILE=ag-ui@0.0.55
LOCAL_BUSINESS_AI_UI_ACTOR_TOKEN_TTL_SECONDS=900
LOCAL_BUSINESS_COPILOTKIT_ENABLED=false
LOCAL_BUSINESS_COPILOTKIT_RUNTIME_URL=/copilotkit
LOCAL_BUSINESS_COPILOTKIT_AGENT_ID=local_business
LOCAL_BUSINESS_COPILOTKIT_ACTOR_TOKEN_TTL_SECONDS=900
LOCAL_BUSINESS_AGENT_RUNTIME_AG_UI_URL=http://127.0.0.1:8090/ag-ui
COPILOTKIT_RUNTIME_PORT=3100
COPILOTKIT_BASE_PATH=/copilotkit
COPILOTKIT_TELEMETRY_DISABLED=true
GUNICORN_TIMEOUT=600
GUNICORN_GRACEFUL_TIMEOUT=30
LOCAL_BUSINESS_PERFORMANCE_METRICS_ENABLED=false
LOCAL_BUSINESS_PERFORMANCE_METRICS_PATH=data/logs/performance_events.jsonl
LOCAL_BUSINESS_PERFORMANCE_METRICS_SAMPLE_RATE=1.0
LOCAL_BUSINESS_PERFORMANCE_METRICS_EXCLUDE_PREFIXES=/static/,/media/,/favicon.
# IIS/FastCGI-совместимый отладочный контур: PathInfoDebugMiddleware (фикс
# PATH_INFO для IIS) и staff-only /debug-request/ выключены по умолчанию и не
# участвуют в MIDDLEWARE/urlpatterns на Linux/Docker. Включайте только на
# IIS-развёртывании (см. docs/deployment/IIS_SSO.md).
# LOCAL_BUSINESS_IIS_COMPAT_ENABLED=true
# Уровень логгера 'apps.core.iis_path_debug' (пишет в data/logs/iis_path_debug.log
# через RotatingFileHandler с delay=True — без включения ничего не пишется и файл
# не создаётся). По умолчанию WARNING (тихо); для диагностики поднимите до INFO/DEBUG.
# LOCAL_BUSINESS_IIS_PATH_DEBUG_LOG_LEVEL=INFO
LOCAL_BUSINESS_AI_PENDING_ACTION_TTL_SECONDS=900
LOCAL_BUSINESS_SECRET_VAULT_BASE_URL=https://vault.example.local
SETTINGS_CENTER_ENABLED=true
SETTINGS_CENTER_ENV_APPLY_MODE=proposal
SETTINGS_CENTER_ENV_FILE=.env
SETTINGS_CENTER_ENV_PROPOSAL_DIR=data/settings_center/env_proposals
SETTINGS_CENTER_HELP_AI_ENABLED=true
SETTINGS_CENTER_HELP_MODEL_PROFILE=local_admin_help_v1
SETTINGS_CENTER_HELP_MAX_CONTEXT_CHARS=6000
SETTINGS_CENTER_AUDIT_RETENTION_DAYS=365
ACCOUNTS_AD_LINK_ENABLED=true
ACCOUNTS_AD_LINK_MODE=manual
ACCOUNTS_AD_GROUP_ROLE_SYNC=false
MEMORY_ACL_INHERITANCE_ENABLED=true
MEMORY_ACL_FAIL_CLOSED=true
MEMORY_ACL_UNRESOLVED_POLICY=block
MEMORY_ACL_GROUP_NESTING_DEPTH=5
MEMORY_ACL_CACHE_TTL_SECONDS=3600
LOCAL_BUSINESS_AI_REGISTRY_FILE=
LOCAL_BUSINESS_AI_TOOLS_FILE=
LOCAL_BUSINESS_AI_TASK_TYPES_FILE=
LOCAL_BUSINESS_AI_MODELS_FILE=
LOCAL_BUSINESS_ANALYTICS_DATASETS_FILE=
DJANGO_AI_GATEWAY_URL=http://stc-web/ai/gateway
# В проде (особенно при строгом DJANGO_ALLOWED_HOSTS) указывайте хост из ALLOWED_HOSTS,
# иначе Django вернёт 400 DisallowedHost на gateway-вызовах runtime. Например, на
# машине с hostname = stc-web и ALLOWED_HOSTS=[stc-web,web] используйте
# DJANGO_AI_GATEWAY_URL=http://stc-web/ai/gateway
# После правки этого значения обязателен перезапуск runtime (load_dotenv читается один раз).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_AGENT_MODEL=openai:gpt-4.1-mini
AI_AGENT_MODEL_NAME=gpt-4.1-mini
AI_AGENT_SYSTEM_PROMPT_FILE=services/agent_runtime/prompts/hospital_system_prompt.txt
# False values are allowed only for the current HTTP-only trusted LAN/VPN profile.
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
