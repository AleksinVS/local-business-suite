<?xml version="1.0" encoding="UTF-8"?>
    <configuration>
      <location path="." inheritInChildApplications="false">
        <system.webServer>
          <modules runAllManagedModulesForAllRequests="true"></modules>
          <handlers accessPolicy="Read, Execute, Script">
            <add name="Python FastCGI" path="*" verb="*" modules="FastCgiModule" scriptProcessor="C:\inetpub\portal\.venv\Scripts\python.exe|C:\inetpub\portal\.venv\Lib\site-packages\wfastcgi.py" resourceType="Unspecified" requireAccess="Script" allowPathInfo="true" responseBufferLimit="4194304" />
          </handlers>
          <security>
            <authentication>
              <anonymousAuthentication enabled="true" />
              <windowsAuthentication enabled="true" />
            </authentication>
          </security>
          <staticContent>
            <mimeMap fileExtension=".py" mimeType="text/x-python" />
          </staticContent>
        </system.webServer>
      </location>

      <location path="static" inheritInChildApplications="false">
        <system.webServer>
          <handlers>
            <clear />
            <add name="StaticFile" path="*" verb="*" modules="StaticFileModule,DefaultDocumentModule,DirectoryListingModule" resourceType="Either" requireAccess="Read" />
          </handlers>
          <security>
            <authentication>
              <anonymousAuthentication enabled="true" />
              <windowsAuthentication enabled="false" />
            </authentication>
          </security>
        </system.webServer>
      </location>

      <location path="ai/gateway" inheritInChildApplications="false">
        <system.webServer>
          <handlers accessPolicy="Read, Execute, Script">
            <add name="Python FastCGI" path="*" verb="*" modules="FastCgiModule" scriptProcessor="C:\inetpub\portal\.venv\Scripts\python.exe|C:\inetpub\portal\.venv\Lib\site-packages\wfastcgi.py" resourceType="Unspecified" requireAccess="Script" allowPathInfo="true" responseBufferLimit="4194304" />
          </handlers>
          <security>
            <authentication>
              <anonymousAuthentication enabled="true" />
              <windowsAuthentication enabled="false" />
            </authentication>
          </security>
        </system.webServer>
      </location>



      <appSettings>
        <add key="WSGI_HANDLER" value="config.wsgi.application" />
        <add key="PYTHONPATH" value="C:\inetpub\portal" />
        <add key="DJANGO_SETTINGS_MODULE" value="config.settings" />
        <add key="DJANGO_AUTH_MODE" value="hybrid" />
        <add key="WSGI_PythonHome" value="C:\inetpub\portal\.venv" />
        <add key="WSGI_PythonPath" value="C:\inetpub\portal" />
        <!-- wfastcgi per-worker limits: recycle workers periodically and drop idle ones so
             a single hung stream (e.g. waiting on the agent runtime) cannot exhaust the pool. -->
        <add key="instanceMaxRequests" value="2000" />
        <add key="idleTimeoutInSeconds" value="300" />

        <!-- AD/LDAP settings are now loaded from .env file for security -->
        <!-- See IIS_SSO.md and SECURE_SECRETS.md for secure configuration -->
        <!-- Secrets are stored in .env file with restricted file permissions -->
      </appSettings>
    <system.webServer>
        <directoryBrowse enabled="false" />
    </system.webServer>
   </configuration>
