{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Analytics Retention Profiles",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["code", "owner", "raw_retention_days", "normalized_retention_days", "fact_retention_days", "audit_retention_days"],
    "properties": {
      "code": { "type": "string", "minLength": 1 },
      "owner": { "type": "string", "minLength": 1 },
      "raw_retention_days": { "type": "integer", "minimum": 0 },
      "normalized_retention_days": { "type": "integer", "minimum": 0 },
      "fact_retention_days": { "type": "integer", "minimum": 0 },
      "audit_retention_days": { "type": "integer", "minimum": 0 }
    }
  }
}
