{
  "version": "1.0",
  "name": "chat_agent_task_types",
  "description": "Intent catalog for the chat and agent block.",
  "task_types": [
    {
      "id": "workorders.list",
      "title": "List work orders",
      "mode": "read",
      "description": "Show work orders filtered by status or scope.",
      "allowed_tools": [
        "workorders.list"
      ],
      "required_slots": [
        "status_or_scope"
      ],
      "requires_confirmation": false,
      "output_mode": "structured_list",
      "example_requests": [
        "Покажи новые заявки",
        "Какие заявки в работе у меня сейчас?"
      ]
    },
    {
      "id": "workorders.get.detail",
      "title": "Get work order details",
      "mode": "read",
      "description": "Read one work order in detail by ID or number.",
      "allowed_tools": [
        "workorders.get"
      ],
      "required_slots": [],
      "optional_slots": [
        "workorder_id",
        "number"
      ],
      "requires_confirmation": false,
      "output_mode": "result",
      "example_requests": [
        "Покажи подробности заявки 123",
        "Что с заявкой номер REQ-456?"
      ]
    },
    {
      "id": "workorders.create",
      "title": "Create work order",
      "mode": "write",
      "description": "Create a new work order from a conversational request.",
      "allowed_tools": [
        "workorders.create",
        "departments.list",
        "devices.list"
      ],
      "required_slots": [
        "department",
        "subject",
        "description"
      ],
      "optional_slots": [
        "device",
        "priority"
      ],
      "requires_confirmation": true,
      "output_mode": "confirmation_then_result",
      "example_requests": [
        "Создай заявку на починку раковины в стационаре",
        "Нужна заявка на светильник в поликлинике"
      ]
    },
    {
      "id": "workorders.transition",
      "title": "Transition work order",
      "mode": "write",
      "description": "Move a request to the next allowed status.",
      "allowed_tools": [
        "workorders.get",
        "workorders.transition"
      ],
      "required_slots": [
        "workorder",
        "target_status"
      ],
      "optional_slots": [],
      "requires_confirmation": true,
      "output_mode": "confirmation_then_result",
      "example_requests": [
        "Переведи заявку 12 в работу",
        "Закрой заявку 18"
      ]
    },
    {
      "id": "workorders.comment",
      "title": "Comment on work order",
      "mode": "write",
      "description": "Add a comment to a work order timeline.",
      "allowed_tools": [
        "workorders.comment"
      ],
      "required_slots": [
        "workorder",
        "text"
      ],
      "requires_confirmation": false,
      "output_mode": "result",
      "example_requests": [
        "Добавь комментарий к заявке 7: нужен доступ в подвал"
      ]
    },
    {
      "id": "workorders.confirm_closure",
      "title": "Confirm work order closure",
      "mode": "write",
      "description": "Confirm the closure of a resolved work order.",
      "allowed_tools": [
        "workorders.confirm_closure"
      ],
      "required_slots": [
        "workorder_id"
      ],
      "requires_confirmation": true,
      "output_mode": "confirmation_then_result",
      "example_requests": [
        "Подтверди закрытие заявки 123",
        "Заявка 456 выполнена, закрывай"
      ]
    },
    {
      "id": "workorders.rate",
      "title": "Rate work order",
      "mode": "write",
      "description": "Rate a closed work order.",
      "allowed_tools": [
        "workorders.rate"
      ],
      "required_slots": [
        "workorder_id",
