# Required secrets for LibreChat local run.
# Generate with:
# openssl rand -hex 32
# openssl rand -hex 16

JWT_SECRET=replace-with-64-hex-chars
JWT_REFRESH_SECRET=replace-with-64-hex-chars
CREDS_KEY=replace-with-64-hex-chars
CREDS_IV=replace-with-32-hex-chars

# Use your provider key here or set another supported provider in librechat.yaml.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional quality-of-life settings for local development.
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false
ENDPOINTS=openAI
APP_TITLE=Local Business Suite AI Chat
AI_AGENT_MODEL_NAME=gpt-4.1-mini
OPENAI_MODELS=gpt-4.1-mini,gpt-4.1,gpt-4o-mini
LIBRECHAT_PUBLIC_URL=http://localhost:3080
# For production behind Caddy, use: http://<host>/librechat
MEILI_MASTER_KEY=replace-with-64-hex-chars
