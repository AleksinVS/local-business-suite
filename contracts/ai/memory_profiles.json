{
  "version": "1.0",
  "name": "memory_profiles",
  "description": "Default synthetic profiles for chunking, extraction, indexing, and retrieval ranking.",
  "chunking_profiles": {
    "short_business_event_v1": {
      "strategy": "field_aware",
      "max_tokens": 500,
      "overlap_tokens": 60,
      "preserve_fields": [
        "number",
        "status",
        "department",
        "updated_at"
      ]
    },
    "long_policy_doc_v1": {
      "strategy": "heading_aware",
      "max_tokens": 900,
      "overlap_tokens": 120,
      "preserve_fields": [
        "title",
        "section",
        "path"
      ]
    },
    "structured_contract_v1": {
      "strategy": "json_pointer",
      "max_tokens": 700,
      "overlap_tokens": 80,
      "preserve_fields": [
        "name",
        "version",
        "path",
        "json_pointer"
      ]
    },
    "external_api_object_v1": {
      "strategy": "field_aware",
      "max_tokens": 700,
      "overlap_tokens": 80,
      "preserve_fields": [
        "source_code",
        "collection",
        "object_type",
        "external_id",
        "title",
        "source_updated_at"
      ]
    }
  },
  "extractor_profiles": {
    "project_docs_v1": {
      "mode": "text",
      "graph_extraction": false,
      "entity_types": [
        "architecture_decision",
        "component",
        "contract",
        "policy"
      ],
      "requires_local_llm": true
    },
    "contract_json_v1": {
      "mode": "structured_json",
      "graph_extraction": false,
      "entity_types": [
        "contract",
        "schema",
        "field",
        "enum"
      ],
      "requires_local_llm": false
    },
    "workorder_event_v1": {
      "mode": "business_event",
      "graph_extraction": false,
      "entity_types": [
        "work_order",
        "department",
        "device",
        "status"
      ],
      "requires_local_llm": true
    },
    "inventory_device_v1": {
      "mode": "business_object",
      "graph_extraction": false,
      "entity_types": [
        "device",
        "department",
        "manufacturer",
        "device_type"
      ],
      "requires_local_llm": true
    },
    "external_api_object_v1": {
      "mode": "business_object",
      "graph_extraction": false,
      "entity_types": [
        "external_record",
        "department",
        "person",
        "asset",
        "document"
      ],
      "requires_local_llm": true
    }
  },
  "embedding_profiles": {
    "local_hash_test_v1": {
      "provider": "local",
      "model": "local-hash-test-v1",
      "dimensions": 64,
      "normalization": true
    },
    "local_multilingual_v1": {
      "provider": "local",
      "model": "BAAI/bge-m3",
      "dimensions": 1024,
      "normalization": true
    },
    "local_multilingual_baseline_v1": {
      "provider": "local",
      "model": "intfloat/multilingual-e5-large",
      "dimensions": 1024,
      "normalization": true
    }
  },
  "index_profiles": {
    "vector_default": {
      "index_kind": "vector",
      "backend": "lancedb",
      "embedding_profile": "local_hash_test_v1",
      "store_safe_text_only": true,
      "runtime_status": "enabled",
      "runtime_note": "LanceDB vector backend enabled with a local test embedding profile by default; production should switch LOCAL_BUSINESS_MEMORY_EMBEDDING_PROFILE to local_multilingual_v1 after model provisioning."
    },
    "fulltext_default": {
      "index_kind": "fulltext",
      "backend": "sqlite_fts",
      "embedding_profile": null,
      "store_safe_text_only": true,
      "runtime_status": "enabled",
      "runtime_note": "SQLite FTS5 is the primary runtime backend; token fallback remains available when FTS5 is unavailable."
    },
    "graph_default": {
      "index_kind": "graph",
      "backend": "kuzu",
      "embedding_profile": null,
      "store_safe_text_only": true,
      "runtime_status": "disabled",
      "runtime_note": "Graph runtime search отключен; schema bootstrapping и extraction остаются отдельным future-stage контуром."
    }
  },
  "ranking_profiles": {
    "precise": {
      "fusion": "rrf",
      "vector_weight": 0.1,
      "fulltext_weight": 0.9,
      "graph_weight": 0.0,
      "reranker": "none",
      "max_results": 12
    },
    "balanced": {
      "fusion": "rrf",
      "vector_weight": 0.45,
      "fulltext_weight": 0.55,
      "graph_weight": 0.0,
      "reranker": "none",
      "max_results": 12
    },
    "semantic_heavy": {
      "fusion": "rrf",
      "vector_weight": 0.75,
      "fulltext_weight": 0.25,
      "graph_weight": 0.0,
      "reranker": "none",
      "max_results": 12
    },
    "source_content": {
      "fusion": "rrf",
      "vector_weight": 0.3,
      "fulltext_weight": 0.7,
      "graph_weight": 0.0,
      "reranker": "none",
      "max_results": 12
    },
    "source_semantic": {
      "fusion": "rrf",
      "vector_weight": 0.7,
      "fulltext_weight": 0.3,
      "graph_weight": 0.0,
      "reranker": "none",
      "max_results": 12
    },
    "graph_future": {
      "fusion": "rrf",
      "vector_weight": 0.35,
      "fulltext_weight": 0.35,
      "graph_weight": 0.3,
      "reranker": "none",
      "max_results": 12
    }
  }
}
